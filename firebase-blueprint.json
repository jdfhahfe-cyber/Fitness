{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User fitness preferences and profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "targetWeight": { "type": "number" },
        "currentWeight": { "type": "number" },
        "height": { "type": "number" },
        "fitnessGoal": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Workout": {
      "title": "Workout Entry",
      "description": "A single workout session recorded by the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "duration": { "type": "number" },
        "intensity": { "type": "string", "enum": ["low", "medium", "high"] },
        "calories": { "type": "number" },
        "distance": { "type": "number" },
        "notes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "duration", "timestamp"]
    },
    "Milestone": {
      "title": "Milestone",
      "description": "Achievements and milestones earned by the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "achievedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "achievedAt"]
    },
    "TrainingPlan": {
      "title": "AI Training Plan",
      "description": "Personalized training plan generated by Gemini",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["userId", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles"
    },
    "/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "Global workout entries, filtered by userId"
    },
    "/milestones/{milestoneId}": {
      "schema": "Milestone",
      "description": "User achievements"
    },
    "/trainingPlans/{planId}": {
      "schema": "TrainingPlan",
      "description": "Generated training plans"
    }
  }
}
