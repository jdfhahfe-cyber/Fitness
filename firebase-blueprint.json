{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User fitness preferences, currency, streaks, and ranking data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "targetWeight": { "type": "number" },
        "currentWeight": { "type": "number" },
        "height": { "type": "number" },
        "fitnessGoal": { "type": "string" },
        "coins": { "type": "number" },
        "streakCount": { "type": "number" },
        "lastWorkoutDate": { "type": "string", "format": "date" },
        "streakFreezes": { "type": "number" },
        "coinMultiplier": { "type": "number" },
        "league": { "type": "string", "enum": ["Beginner", "Dirt", "Rock", "Legend", "Gold", "Diamond", "Super"] },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "isBanned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Workout": {
      "title": "Workout Entry",
      "description": "A single workout session recorded by the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "duration": { "type": "number" },
        "intensity": { "type": "string", "enum": ["low", "medium", "high"] },
        "calories": { "type": "number" },
        "distance": { "type": "number" },
        "coinsEarned": { "type": "number" },
        "notes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "duration", "timestamp"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Admin broadcast messages",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["ping", "broadcast"] },
        "targetUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles"
    },
    "/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "Global workout entries"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Admin messages"
    }
  }
}
